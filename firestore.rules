rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.email is string && 
             data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             data.createdAt is string &&
             data.linkedAccounts is map &&
             data.linkedAccounts.get('facebook', false) is bool;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().email == request.auth.token.email &&
                      incoming().createdAt == request.time.toTimestamp().toString(); // Best effort for string format if initialized as string, usually better as timestamp though. 
                      // Actually, let's fix the schema/app to use serverTimestamp for real rules.
                      // For now, based on the context of my app creation:
      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().email == existing().email &&
                      incoming().createdAt == existing().createdAt &&
                      (
                        // Action: Update Profile Info
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'linkedAccounts'])
                      );
      
      allow delete: if false; // Users cannot delete profiles for now
    }
  }
}
